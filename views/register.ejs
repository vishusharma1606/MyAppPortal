<!doctype html>
<html>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Register - Simple Auth App</title>
    <link rel="stylesheet" href="/style.css" />
  </head>
  <body>
    <header>
      <h1>Simple Auth App</h1>
    </header>
    <main>
      <section class="auth">
        <% if (error) { %>
          <div class="flash error"><span class="msg"><%= error %></span><button class="close" aria-label="Dismiss">&times;</button></div>
        <% } %>
        <div class="forms">
          <form method="post" action="/register" class="card">
            <h2>Create Account</h2>
            <label>Username</label>
            <input name="username" />
            <label>Password</label>
            <input type="password" name="password" />
            <button type="submit">Register</button>
          </form>
          <div class="card register-card">
            <h2>Already registered?</h2>
            <p>Use your account to login.</p>
            <a class="secondary-button" href="/">Login instead</a>
          </div>
        </div>
      </section>
    </main>
    <script src="/app.js"></script>
  </body>
</html>
